{
	"name": "4viewture/course",
	"description": "allows to import serveral courses from exchangeable providers",
	"type": "typo3-cms-extension",
	"license": [
		"GPL-2.0+"
	],
	"keywords": [
		"TYPO3",
		"extension"
	],
	"authors": [
		{
			"name": "Kay Strobach",
			"email": "hello@4viewture.de",
			"homepage": "https:\/\/www.4viewture.de",
			"role": "Developer"
		}
	],
	"homepage": "https:\/\/www.4viewture.de",
	"require": {
		"typo3\/cms-core": "^12.4 || ^13.4 || ^14",
		"symfony/polyfill-php83": "*",
		"swaggest/json-schema": "*",
		"friendsoftypo3/tt-address": "*"
	},
	"require-dev": {
		"phpunit\/phpunit": "^5.6"
	},
	"autoload": {
		"psr-4": {
			"FourViewture\\Course\\": "Classes\/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"TYPO3\\CMS\\Core\\Tests\\": "..\/..\/typo3\/sysext\/core\/Tests\/",
			"TYPO3\\CMS\\Fluid\\Tests\\": "..\/..\/typo3\/sysext\/fluid\/Tests\/"
		}
	},
	"config": {
		"bin-dir": ".Build\/bin\/",
		"vendor-dir": ".Build\/vendor\/"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "course"
		}
	}
}
